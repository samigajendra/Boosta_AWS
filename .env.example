# AWS Credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# S3 Storage
S3_BUCKET_NAME=your_bucket_name_here

# Database
# If using RDS: postgres://user:password@endpoint:5432/dbname
# If testing locally with SQLite: leave blank or comment out
DATABASE_URL=

# Server Port
PORT=5000
